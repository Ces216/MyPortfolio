  <script>
    // ───────────────────────────
    // 1. CURSOR PERSONALIZADO
    // ───────────────────────────
    const cursor     = document.getElementById('cursor');
    const cursorRing = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;

    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      cursor.style.transform = `translate(${mx - 6}px, ${my - 6}px)`;
    });

    // El anillo sigue con lerp (suavizado)
    (function animateRing() {
      rx += (mx - rx) * 0.12;
      ry += (my - ry) * 0.12;
      cursorRing.style.transform = `translate(${rx - 18}px, ${ry - 18}px)`;
      requestAnimationFrame(animateRing);
    })();

    // Agrandar cursor sobre elementos interactivos
    document.querySelectorAll('a, button, .project-card, .tech-pill, .stat-card').forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursor.style.transform += ' scale(1.5)';
        cursorRing.style.transform += ' scale(1.8)';
        cursorRing.style.opacity = '0.8';
      });
      el.addEventListener('mouseleave', () => {
        cursorRing.style.opacity = '0.5';
      });
    });

    // ───────────────────────────
    // 2. NAVBAR al scroll
    // ───────────────────────────
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 50);
    });

    // ───────────────────────────
    // 3. PARALLAX (hero)
    // ───────────────────────────
    const parallaxBg   = document.getElementById('parallax-bg');
    const parallaxGrid = document.getElementById('parallax-grid');

    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      // El fondo se mueve 40% de la velocidad del scroll (más lento → sensación de profundidad)
      parallaxBg.style.transform   = `translateY(${y * 0.4}px)`;
      // El grid se mueve un poco menos rápido
      parallaxGrid.style.transform = `translateY(${y * 0.25}px)`;
    });

    // ───────────────────────────
    // 4. EFECTO TYPING en el nombre
    // ───────────────────────────
    const name = 'Tu Nombre.';     // ← CAMBIA ESTO
    const el   = document.getElementById('typed-name');
    let i = 0;

    function typeChar() {
      if (i < name.length) {
        el.textContent += name[i++];
        setTimeout(typeChar, 100 + Math.random() * 60);
      }
    }
    setTimeout(typeChar, 1000);  // empieza 1s después de cargar

    // ───────────────────────────
    // 5. REVEAL al hacer scroll (IntersectionObserver)
    // ───────────────────────────
    const reveals = document.querySelectorAll('.reveal');

    const observer = new IntersectionObserver(entries => {
      entries.forEach((entry, idx) => {
        if (entry.isIntersecting) {
          // Retraso escalonado para elementos del mismo grupo
          entry.target.style.transitionDelay = `${idx * 0.07}s`;
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    reveals.forEach(el => observer.observe(el));

    // ───────────────────────────
    // 6. Contador animado de stats
    // ───────────────────────────
    function animateCount(el, end, duration = 1500) {
      let start = 0;
      const step = end / (duration / 16);
      const timer = setInterval(() => {
        start = Math.min(start + step, end);
        el.textContent = Math.floor(start) + (el.dataset.suffix || '+');
        if (start >= end) clearInterval(timer);
      }, 16);
    }

    const statsObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll('.stat-number[data-target]').forEach(n => {
            animateCount(n, parseInt(n.dataset.target));
          });
          statsObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('.about-stats').forEach(s => statsObserver.observe(s));
  </script>
